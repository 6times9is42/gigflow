# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
# For local dev: mongodb://localhost:27017/smart-leads
# For Docker Compose: mongodb://mongo:27017/smart-leads  (overridden automatically)
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/smart-leads
MONGODB_URI=mongodb://mongo:27017/smart-leads
# Must be at least 32 random characters — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-32-plus-char-random-secret
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGIN=http://localhost:3000

# ── Client build arg (passed to docker-compose) ──────────────────
VITE_API_URL=http://localhost:5000/api
